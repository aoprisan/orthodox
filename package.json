{
  "name": "orthodox-calendar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && cross-env MOBILE=1 vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "build:synaxarion": "node scripts/buildExtendedSynaxarion.mjs",
    "build:lives": "node scripts/buildSynaxarLives.mjs",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "npm run build:mobile && cap run ios",
    "cap:run:android": "npm run build:mobile && cap run android",
    "build:android": "bash scripts/build-android.sh",
    "build:android:release": "bash scripts/build-android.sh --release",
    "build:android:bundle": "bash scripts/build-android.sh --aab",
    "build:ios": "bash scripts/build-ios.sh",
    "build:ios:simulator": "bash scripts/build-ios.sh --simulator",
    "build:ios:archive": "bash scripts/build-ios.sh --archive-only",
    "clean:android": "bash scripts/clean-android.sh",
    "clean:ios": "bash scripts/clean-ios.sh",
    "clean:mobile": "bash scripts/clean-mobile.sh",
    "clean:mobile:deep": "bash scripts/clean-mobile.sh --deep"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^10.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
